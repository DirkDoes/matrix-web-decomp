<%
  profile_name = current_user.name.presence || current_user.email_address.to_s.split("@").first.to_s.humanize
  profile_tokens = profile_name.scan(/[A-Za-z0-9]+/)
  profile_initials = if profile_tokens.size >= 2
    "#{profile_tokens[0][0]}#{profile_tokens[1][0]}"
  else
    profile_tokens.first.to_s[0, 2]
  end
  profile_initials = profile_initials.upcase.presence || "DE"
  settings_section = controller_path.start_with?("settings/")
  theme_preference = current_user.theme_preference.presence_in(User::THEME_PREFERENCES) || "system"
  icon = ->(name) { File.read(Rails.root.join("public/icons/#{name}.svg")).html_safe }
  primary_nav_items = [
    {
      label: "Dashboard",
      path: overview_path,
      key: "dashboard",
      active: controller_name == "overview",
      icon: "dashboard"
    }
  ]
%>

<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || (settings_section ? "Settings - Detrix" : "Detrix") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="turbo-prefetch" content="false">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "logged_in", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags "main" %>
  </head>

  <body class="logged-in-body theme-<%= theme_preference %>">
    <% if overlay_flash_messages.any? %>
      <div class="app-flash-stack" aria-live="polite" aria-atomic="true">
        <% overlay_flash_messages.each do |flash_message| %>
          <div class="app-flash app-flash-<%= flash_message[:tone] %>">
            <%= flash_message[:message] %>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="logged-in-shell" data-controller="sidebar">
      <header class="logged-in-mobile-topbar">
        <details class="logged-in-mobile-menu" data-controller="profile-menu">
          <summary class="logged-in-mobile-icon-button" aria-label="Open navigation menu">
            <span class="logged-in-mobile-hamburger" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </span>
          </summary>

          <div class="logged-in-mobile-context-menu logged-in-mobile-nav-panel">
            <nav class="logged-in-mobile-nav" aria-label="Primary navigation">
              <% primary_nav_items.each do |item| %>
                <%= link_to item[:path], class: "logged-in-sidebar-link #{'active' if item[:active]}", data: { sidebar_target: "item", sidebar_key: item[:key], action: "pointerdown->sidebar#select", turbo_frame: "app_content", turbo_action: "advance" } do %>
                  <span class="logged-in-sidebar-icon" aria-hidden="true">
                    <%= icon.call(item[:icon]) %>
                  </span>
                  <span><%= item[:label] %></span>
                <% end %>
              <% end %>
            </nav>
          </div>
        </details>

        <div class="logged-in-mobile-brand">Detrix</div>

        <details class="logged-in-mobile-menu" data-controller="profile-menu">
          <summary class="logged-in-mobile-profile-summary" aria-label="Open profile menu">
            <div class="logged-in-profile-avatar" aria-hidden="true"><%= profile_initials %></div>
          </summary>

          <div class="logged-in-mobile-context-menu logged-in-mobile-profile-panel">
            <div class="logged-in-mobile-profile-card">
              <p class="logged-in-mobile-profile-name"><%= profile_name %></p>
              <p class="logged-in-mobile-profile-email"><%= current_user.email_address %></p>
            </div>

            <% if settings_access? %>
              <%= link_to "Settings", settings_path, class: "logged-in-context-link", data: { turbo_frame: "app_content", turbo_action: "advance", turbo_prefetch: false } %>
            <% end %>

            <%= link_to "Personal settings", edit_settings_user_path(current_user), class: "logged-in-context-link", data: { turbo_frame: "app_content", turbo_action: "advance", turbo_prefetch: false } %>

            <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "logged-in-context-logout" %>
          </div>
        </details>
      </header>

      <aside class="logged-in-sidebar">
        <div class="logged-in-sidebar-inner">
          <div>
            <div class="logged-in-brand">
              <span class="logged-in-brand-mark" aria-hidden="true">
                <%= icon.call("brand") %>
              </span>
              <span>Detrix</span>
            </div>

            <nav class="logged-in-sidebar-nav" aria-label="Primary navigation">
              <p class="logged-in-nav-label">general</p>

              <% primary_nav_items.each do |item| %>
                <%= link_to item[:path], class: "logged-in-sidebar-link #{'active' if item[:active]}", data: { sidebar_target: "item", sidebar_key: item[:key], action: "pointerdown->sidebar#select", turbo_frame: "app_content", turbo_action: "advance" } do %>
                  <span class="logged-in-sidebar-icon" aria-hidden="true">
                    <%= icon.call(item[:icon]) %>
                  </span>
                  <span><%= item[:label] %></span>
                <% end %>
              <% end %>
            </nav>
          </div>

          <div class="logged-in-sidebar-footer">
            <details class="logged-in-profile-menu" data-controller="profile-menu">
              <summary class="logged-in-profile-summary">
                <div class="logged-in-profile-avatar" aria-hidden="true"><%= profile_initials %></div>

                <div class="logged-in-profile-copy">
                  <p class="logged-in-profile-name"><%= profile_name %></p>
                  <p class="logged-in-profile-email"><%= current_user.email_address %></p>
                </div>
              </summary>

              <div class="logged-in-context-menu">
                <% if settings_access? %>
                  <%= link_to "Settings", settings_path, class: "logged-in-context-link", data: { turbo_frame: "app_content", turbo_action: "advance", turbo_prefetch: false } %>
                <% end %>

                <%= link_to "Personal settings", edit_settings_user_path(current_user), class: "logged-in-context-link", data: { turbo_frame: "app_content", turbo_action: "advance", turbo_prefetch: false } %>

                <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "logged-in-context-logout" %>
              </div>
            </details>
          </div>
        </div>
      </aside>

      <main class="logged-in-main">
        <%= turbo_frame_tag "app_content" do %>
          <% if settings_section && settings_access? %>
            <nav class="settings-subnav" aria-label="Settings navigation">
              <%= link_to "Users", settings_users_path, class: "settings-subnav-link #{'active' if controller_name == 'users'}" %>
            </nav>
          <% end %>

          <%= yield %>
        <% end %>
      </main>
    </div>
  </body>
</html>
