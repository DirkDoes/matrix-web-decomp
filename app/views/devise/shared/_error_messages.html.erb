<% if resource.errors.any? %>
  <div class="alert alert-error">
    <strong><%= pluralize(resource.errors.count, "error") %> blocked this request:</strong>
    <ul>
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>