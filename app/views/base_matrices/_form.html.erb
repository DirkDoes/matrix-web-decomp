<section class="matrix-form-page" aria-labelledby="matrix-form-title">
  <header class="matrix-form-header">
    <%= link_to "Matrices", base_matrices_path, class: "settings-back-link", data: { turbo_frame: "app_content", turbo_action: "advance" } %>
    <h1 id="matrix-form-title"><%= form_title %></h1>
  </header>

  <%= form_with model: base_matrix, class: "matrix-form", data: { controller: "matrix-form" } do |form| %>
    <% if base_matrix.errors.any? %>
      <div class="form-errors">
        <p><%= pluralize(base_matrix.errors.count, "error") %> prevented this matrix from being saved.</p>
      </div>
    <% end %>

    <div class="matrix-form-grid">
      <div class="matrix-form-fields">
        <div class="form-group">
          <%= form.label :title %>
          <%= form.text_field :title, data: { matrix_form_target: "title" } %>
        </div>

        <div class="matrix-dimension-grid">
          <div class="form-group">
            <%= form.label :x_count, "X" %>
            <%= form.number_field :x_count, min: BaseMatrix::MIN_COUNT, max: BaseMatrix::MAX_COUNT, data: { matrix_form_target: "xInput", action: "input->matrix-form#update" } %>
          </div>

          <div class="form-group">
            <%= form.label :y_count, "Y" %>
            <%= form.number_field :y_count, min: BaseMatrix::MIN_COUNT, max: BaseMatrix::MAX_COUNT, data: { matrix_form_target: "yInput", action: "input->matrix-form#update" } %>
          </div>

          <div class="form-group">
            <%= form.label :z_count, "Z" %>
            <%= form.number_field :z_count, min: BaseMatrix::MIN_COUNT, max: BaseMatrix::MAX_COUNT, data: { matrix_form_target: "zInput", action: "input->matrix-form#update" } %>
          </div>
        </div>

        <div class="matrix-form-actions">
          <%= form.submit class: "btn btn-primary" %>
          <%= link_to "Cancel", base_matrices_path, class: "btn btn-secondary", data: { turbo_frame: "app_content", turbo_action: "advance" } %>
        </div>
      </div>

      <div
        class="matrix-form-preview dashboard-cube-stage"
        data-controller="matrix-viewer"
        data-matrix-form-target="preview"
        data-matrix-viewer-axes-value="false"
        data-matrix-viewer-x-count-value="<%= base_matrix.x_count %>"
        data-matrix-viewer-y-count-value="<%= base_matrix.y_count %>"
        data-matrix-viewer-z-count-value="<%= base_matrix.z_count %>">
        <canvas
          class="dashboard-cube-canvas"
          data-matrix-viewer-target="canvas"
          aria-label="Interactive matrix preview"></canvas>
        <span class="matrix-focus-pie" data-matrix-viewer-target="focusPie" aria-hidden="true"></span>
      </div>
    </div>
  <% end %>
</section>
