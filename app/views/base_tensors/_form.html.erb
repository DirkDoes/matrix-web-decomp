<section class="tensor-form-page" aria-labelledby="tensor-form-title">
  <header class="settings-header tensor-form-header">
    <h1 id="tensor-form-title"><%= form_title %></h1>
  </header>

  <%= form_with model: base_tensor, class: "settings-form tensor-form", data: { controller: "tensor-form", tensor_form_template_preview_url_value: template_preview_base_tensors_path } do |form| %>
    <% if base_tensor.errors.any? %>
      <div class="form-errors">
        <p><%= pluralize(base_tensor.errors.count, "error") %> prevented this tensor from being saved.</p>
        <ul>
          <% base_tensor.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="tensor-form-grid">
      <div class="tensor-form-card tensor-form-fields">
        <div class="form-group">
          <%= form.label :title %>
          <%= form.text_field :title, data: { tensor_form_target: "title" } %>
        </div>

        <div class="form-group">
          <%= label_tag :tensor_template, "Template" %>
          <%= select_tag :tensor_template, options_for_select([["Custom", "custom"], ["Matrix Multiplication", "multiplication"]]), class: "form-select", data: { tensor_form_target: "templateSelect", action: "change->tensor-form#templateChanged" } %>
        </div>

        <p class="tensor-template-message" data-tensor-form-target="templateMessage" hidden></p>

        <%= form.hidden_field :tensor, value: base_tensor.tensor.to_json, data: { tensor_form_target: "tensorInput" } %>

        <div class="tensor-dimension-grid" data-tensor-form-target="customFields">
          <div class="form-group">
            <%= form.label :x_count, "X" %>
            <%= form.number_field :x_count, min: BaseTensor::MIN_COUNT, max: BaseTensor::MAX_COUNT, data: { tensor_form_target: "xInput", action: "input->tensor-form#update" } %>
          </div>

          <div class="form-group">
            <%= form.label :y_count, "Y" %>
            <%= form.number_field :y_count, min: BaseTensor::MIN_COUNT, max: BaseTensor::MAX_COUNT, data: { tensor_form_target: "yInput", action: "input->tensor-form#update" } %>
          </div>

          <div class="form-group">
            <%= form.label :z_count, "Z" %>
            <%= form.number_field :z_count, min: BaseTensor::MIN_COUNT, max: BaseTensor::MAX_COUNT, data: { tensor_form_target: "zInput", action: "input->tensor-form#update" } %>
          </div>
        </div>

        <div class="tensor-template-fields" data-tensor-form-target="multiplicationFields" hidden>
          <div class="tensor-template-factor">
            <h2>Matrix A</h2>
            <div class="tensor-dimension-grid">
              <div class="form-group">
                <%= label_tag :a_rows, "Rows" %>
                <%= number_field_tag :a_rows, 2, min: BaseTensor::MIN_COUNT, max: BaseTensor::MAX_COUNT, data: { tensor_form_target: "aRowsInput", action: "input->tensor-form#templateDimensionChanged" } %>
              </div>

              <div class="form-group">
                <%= label_tag :a_columns, "Columns" %>
                <%= number_field_tag :a_columns, 2, min: BaseTensor::MIN_COUNT, max: BaseTensor::MAX_COUNT, data: { tensor_form_target: "aColumnsInput", action: "input->tensor-form#templateDimensionChanged" } %>
              </div>
            </div>
          </div>

          <div class="tensor-template-factor">
            <h2>Matrix B</h2>
            <div class="tensor-dimension-grid">
              <div class="form-group">
                <%= label_tag :b_rows, "Rows" %>
                <%= number_field_tag :b_rows, 2, min: BaseTensor::MIN_COUNT, max: BaseTensor::MAX_COUNT, disabled: true, data: { tensor_form_target: "bRowsInput" } %>
              </div>

              <div class="form-group">
                <%= label_tag :b_columns, "Columns" %>
                <%= number_field_tag :b_columns, 2, min: BaseTensor::MIN_COUNT, max: BaseTensor::MAX_COUNT, data: { tensor_form_target: "bColumnsInput", action: "input->tensor-form#templateDimensionChanged" } %>
              </div>
            </div>
          </div>
        </div>

        <div class="tensor-form-actions">
          <%= form.submit class: "btn btn-primary" %>
          <%= link_to "Cancel", base_tensors_path, class: "btn btn-secondary", data: { turbo_frame: "app_content", turbo_action: "advance" } %>
        </div>
      </div>

      <div
        class="tensor-form-preview-background dashboard-cube-stage"
        data-controller="tensor-viewer"
        data-tensor-form-target="preview"
        data-tensor-viewer-axes-value="false"
        data-tensor-viewer-editable-value="true"
        data-tensor-viewer-focus-selector-value=".tensor-form-preview-anchor"
        data-tensor-viewer-reset-always-value="true"
        data-tensor-viewer-tensor-value="<%= base_tensor.tensor.to_json %>"
        data-tensor-viewer-x-count-value="<%= base_tensor.x_count %>"
        data-tensor-viewer-y-count-value="<%= base_tensor.y_count %>"
        data-tensor-viewer-z-count-value="<%= base_tensor.z_count %>">
        <canvas
          class="dashboard-cube-canvas"
          data-tensor-viewer-target="canvas"
          aria-label="Interactive tensor preview"></canvas>
      </div>
      <div class="tensor-form-preview-anchor" aria-hidden="true"></div>
    </div>
  <% end %>
</section>
