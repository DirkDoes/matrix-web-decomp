<% content_for :title, "#{@base_matrix.title} - Detrix" %>

<section class="dashboard-cube-page matrix-show-page" aria-label="<%= @base_matrix.title %> interactive matrix">
  <div
    class="dashboard-cube-stage"
    data-controller="rotating-cube"
    data-rotating-cube-x-count-value="<%= @base_matrix.x_count %>"
    data-rotating-cube-y-count-value="<%= @base_matrix.y_count %>"
    data-rotating-cube-z-count-value="<%= @base_matrix.z_count %>">
    <canvas class="dashboard-cube-canvas" data-rotating-cube-target="canvas" aria-label="Draggable 3D matrix"></canvas>
  </div>
</section>
