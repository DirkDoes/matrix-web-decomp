<% content_for :title, "Tensors - Detrix" %>
<% tensor_count = @base_tensors.length %>

<section class="tensors-page" aria-labelledby="tensors-title">
  <header class="tensors-page-header">
    <div class="tensors-page-title">
      <h1 id="tensors-title">Tensors</h1>
      <span class="tensors-count-badge" aria-label="<%= pluralize(tensor_count, "tensor") %>"><%= tensor_count %></span>
    </div>

    <%= link_to "Create tensor", new_base_tensor_path, class: "btn tensors-create-button", data: { turbo_frame: "app_content", turbo_action: "advance" } %>

    <details class="tensors-page-menu" data-controller="profile-menu">
      <summary class="app-context-menu-trigger tensors-page-menu-button" aria-label="Open tensor page actions">
        <span></span>
        <span></span>
        <span></span>
      </summary>

      <div class="app-context-menu tensors-page-menu-panel">
        <%= link_to "Create tensor", new_base_tensor_path, class: "app-context-menu-item", data: { turbo_frame: "app_content", turbo_action: "advance" } %>
      </div>
    </details>
  </header>

  <div class="tensor-card-grid">
    <% @base_tensors.each do |base_tensor| %>
      <article class="tensor-card">
        <details class="tensor-card-menu" data-controller="profile-menu">
          <summary class="app-context-menu-trigger tensor-card-menu-button" aria-label="Open tensor actions">
            <span></span>
            <span></span>
            <span></span>
          </summary>

          <div class="app-context-menu tensor-card-menu-panel">
            <%= link_to "Edit", edit_base_tensor_path(base_tensor), class: "app-context-menu-item tensor-card-menu-link", data: { turbo_frame: "app_content", turbo_action: "advance" } %>
            <%= button_to "Delete", base_tensor_path(base_tensor), method: :delete, class: "app-context-menu-item tensor-card-menu-button-link", form: { data: { turbo_confirm: "Delete this tensor?" } } %>
          </div>
        </details>

        <%= link_to base_tensor_path(base_tensor), class: "tensor-card-link", data: { turbo_frame: "app_content", turbo_action: "advance" } do %>
          <div class="tensor-card-preview">
            <div
              class="dashboard-cube-stage tensor-card-preview-stage"
              data-controller="tensor-viewer"
              data-tensor-viewer-interactive-value="false"
              data-tensor-viewer-axes-value="false"
              data-tensor-viewer-x-count-value="<%= base_tensor.x_count %>"
              data-tensor-viewer-y-count-value="<%= base_tensor.y_count %>"
              data-tensor-viewer-z-count-value="<%= base_tensor.z_count %>"
              data-tensor-viewer-tensor-value="<%= base_tensor.tensor.to_json %>">
              <canvas
                class="dashboard-cube-canvas"
                data-tensor-viewer-target="canvas"
                aria-label="<%= base_tensor.title %> preview"></canvas>
            </div>
          </div>

          <div class="tensor-card-body">
            <h2><%= base_tensor.title %></h2>
            <p><%= base_tensor.size_label %></p>
          </div>
        <% end %>
      </article>
    <% end %>
  </div>
</section>
