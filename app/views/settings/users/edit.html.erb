<div class="settings-header">
  <h1>Edit User</h1>
  <%= link_to "← Back", (@user == current_user && !settings_access?) ? base_tensors_path : settings_users_path, class: "settings-back-link" %>
</div>

<section class="settings-section settings-form-card">
  <%= form_with model: @user, url: settings_user_path(@user), class: "settings-form" do |f| %>
    <div class="form-group">
      <%= f.label :name %>
      <%= f.text_field :name, required: true %>
    </div>

    <div class="form-group">
      <label>Email</label>
      <input type="text" value="<%= @user.email_address %>" disabled class="disabled">
    </div>

    <% if @can_edit_role %>
      <div class="form-group">
        <%= f.label :role %>
        <%= f.select :role, @role_options.map { |role| [role.capitalize, role] }, {}, class: "form-select" %>
      </div>
    <% end %>

    <div class="form-actions">
      <%= f.submit "Save Changes", class: "btn btn-primary" %>
      <%= link_to "Cancel", (@user == current_user && !settings_access?) ? base_tensors_path : settings_users_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</section>
